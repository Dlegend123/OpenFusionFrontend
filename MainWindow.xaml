<Window x:Class="fflauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:fflauncher"
        mc:Ignorable="d"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        Visibility="Hidden"
        ShowInTaskbar="False"
        Background="Transparent"
        Title="OpenFusion Launcher">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Style x:Key="CarouselItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,18,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                CornerRadius="12"
                                Background="{TemplateBinding Background}"
                                SnapsToDevicePixels="True"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.Effect>
                                <DropShadowEffect Color="#001822"
                                                  BlurRadius="18"
                                                  ShadowDepth="0"
                                                  Opacity="0.18"/>
                            </Border.Effect>
                            <ContentPresenter/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource CardColor}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                                <Setter TargetName="Root" Property="BorderThickness" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Viewbox Stretch="Fill"
         StretchDirection="Both" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Border x:Name="RootBorder"
            Background="{DynamicResource BgColor}"
            BorderBrush="{DynamicResource BorderColor}"
            BorderThickness="1"
            CornerRadius="12"
            SnapsToDevicePixels="True"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">

            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Title -->
                <RowDefinition Height="Auto"/>
                <!-- Header -->
                <RowDefinition Height="*"/>
                <!-- MAIN CONTENT (FIXED) -->
                <RowDefinition Height="Auto"/>
                <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Border Grid.Row="0"
                    Background="{DynamicResource BgColor}"
                    MouseDown="Window_MouseDown"
                    x:Name="TitleBar"
                    Panel.ZIndex="1"
                    CornerRadius="12,12,0,0"
                    SnapsToDevicePixels="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="14,0,0,0">
                            <Image x:Name="TitleIcon"
                           Source="/OpenFusion.ico"
                           Width="24"
                            Height="24"
                           Margin="0,0,6,0"/>
                                    <TextBlock x:Name="TitleTextBlock"
                               Text="FusionFall Frontend"
                               Foreground="{DynamicResource FgColor}"
                               FontWeight="Bold"/>  
                        </StackPanel>

                        <Button x:Name="BackButton"
                            Grid.Column="1"
                            Content="←"
                            Width="40"
                            Height="32"
                            Margin="0"
                            FontFamily="Segoe UI Symbol"
                            FontSize="16"
                            Foreground="{DynamicResource FgColor}"
                             Visibility="Hidden"
                            Click="BackButton_Click"
                            Style="{StaticResource TitleBarButtonStyle}"/>

                    <Button Grid.Column="2"
                            Content="—"
                            Width="40"
                            Height="32"
                            Margin="0"
                            FontFamily="Segoe UI Symbol"
                            FontSize="16"
                            Foreground="{DynamicResource FgColor}"
                            Click="Minimize_Click"
                            Style="{StaticResource TitleBarButtonStyle}"/>

                    <Button Grid.Column="3"
                            Content="□"
                            Width="40"
                            Height="32"
                            Margin="0"
                            Name="MaximizeButton"
                            FontFamily="Segoe UI Symbol"
                            FontSize="16"
                            Foreground="{DynamicResource FgColor}"
                            Click="Maximize_Click"
                            Style="{StaticResource TitleBarButtonStyle}"/>

                    <Button Grid.Column="4"
                            Content="X"
                            Width="40"
                            Height="32"
                            Margin="0"
                            FontFamily="Segoe UI Symbol"
                            FontSize="16"
                            Foreground="{DynamicResource FgColor}"
                            Click="Close_Click"
                            Style="{StaticResource TitleBarCloseButtonStyle}"/>
                </Grid>
            </Border>

            <!-- LAUNCHER HEADER -->
            <Border Grid.Row="1"
                    x:Name="LauncherHeader"
                    Background="{DynamicResource CardColor}"
                    CornerRadius="12"
                    Margin="20,10,20,10"
                    Padding="16"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center">
                        <TextBlock Text="Choose Server" FontSize="18" FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBlock Text="Swipe through your available launch targets." FontSize="13" Opacity="0.75"/>
                    </StackPanel>

                    <Button x:Name="SettingsButton"
                            Grid.Row="0"
                            Grid.Column="1"
                            VerticalAlignment="Top"
                            Width="110"
                            Height="40"
                            Content="Settings"
                            Click="SettingsButton_Click"/>
                </Grid>
            </Border>

            <!-- SETTINGS HEADER -->
            <Border Grid.Row="1"
                    x:Name="SettingsHeader"
                    Visibility="Collapsed"
                    Background="{DynamicResource CardColor}"
                    CornerRadius="12"
                    Padding="16"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1" Margin="20,10,20,0">
                <TextBlock Text="Settings"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{DynamicResource FgColor}"/>
            </Border>

            <!-- MAIN VIEWS -->
            <Grid Grid.Row="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <Grid x:Name="LauncherView" Visibility="Visible" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource CardColor}"
                            CornerRadius="12"
                            Margin="20,10,20,0"
                            Width="1000"
                            Padding="16"
                            BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1">
                        <ListBox x:Name="ServerCarousel"
                                 Margin="0"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                 SelectionMode="Single"
                                 IsSynchronizedWithCurrentItem="True"
                                 ItemContainerStyle="{StaticResource CarouselItemStyle}"
                                 PreviewMouseLeftButtonDown="Carousel_MouseDown"
                                 PreviewMouseMove="Carousel_MouseMove"
                                 PreviewMouseLeftButtonUp="Carousel_MouseUp"
                                 MouseLeftButtonUp="ServerCarousel_MouseLeftButtonUp"
                                 SelectionChanged="ServerCarousel_SelectionChanged">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="300"
                                                Height="200"
                                                CornerRadius="12"
                                                ClipToBounds="True">
                                            <Grid>
                                                <!-- NORMAL CONFIG -->
                                                <Grid x:Name="NormalCard">
                                                    <Grid.Clip>
                                                        <RectangleGeometry RadiusX="12"
                                                                           RadiusY="12"
                                                                           Rect="0,0,300,200"/>
                                                    </Grid.Clip>

                                                    <Image Stretch="UniformToFill"
                                                           Opacity="0.75">
                                                            <Image.Style>
                                                                <Style TargetType="Image">
                                                                    <Setter Property="Source" Value="{Binding Image}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsAddNew}" Value="True">
                                                                            <Setter Property="Source" Value="{x:Null}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Image.Style>
                                                    </Image>
                                                            <Border x:Name="Placeholder"
                                                                    Background="#FF2B2F36"
                                                                    Visibility="Collapsed">
                                                                <TextBlock Text="No image"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="White"
                                                                           Opacity="0.7"
                                                                           FontSize="14"
                                                                           FontWeight="Bold"/>
                                                            </Border>
                                                    <Border Background="#66000000"/>
                                                    <StackPanel Margin="14" VerticalAlignment="Bottom">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="16"
                                                                   FontWeight="Bold"
                                                                   Foreground="{DynamicResource FgColor}"/>
                                                        <TextBlock Text="{Binding Address}"
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource AccentColor}"
                                                                   Opacity="0.95"/>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- ADD NEW TILE -->
                                                <Border x:Name="AddTile"
                                                        Background="{DynamicResource CardColor}"
                                                        BorderBrush="{DynamicResource BorderColor}"
                                                        BorderThickness="1"
                                                        CornerRadius="12"
                                                        Visibility="Collapsed">
                                                    <Button Click="AddTile_Click"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Cursor="Hand"
                                                            Padding="0"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Stretch">
                                                        <TextBlock Text="+"
                                                                   FontSize="42"
                                                                   FontWeight="Bold"
                                                                   Foreground="{DynamicResource AccentColor}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Button>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding Image}" Value="{x:Null}">
                                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsAddNew}" Value="True">
                                                <Setter TargetName="NormalCard" Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="AddTile" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  Margin="10"
                                  x:Name="ConfigScrollViewer"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Hidden"
                                  PanningMode="VerticalOnly"
                                  CanContentScroll="False"
                                  PreviewMouseLeftButtonDown="ConfigDrag_MouseDown"
                                  PreviewMouseMove="ConfigDrag_MouseMove"
                                  PreviewMouseLeftButtonUp="ConfigDrag_MouseUp">
                        <StackPanel x:Name="ConfigDetailsPanel"/>
                    </ScrollViewer>
                </Grid>

                    <!-- SETTINGS VIEW -->
                    <Grid x:Name="SettingsView" Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="20">

                        <Grid x:Name="SettingsColumnsGrid" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <!-- Left panel -->
                                <ColumnDefinition Width="2*" />
                                <!-- Server + Account / Theme -->
                            </Grid.ColumnDefinitions>

                            <!-- LEFT PANEL -->
                            <Border Grid.Column="0"
                Background="{DynamicResource CardColor}"
                CornerRadius="12"
                Padding="14"
                Margin="0,0,20,0"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1"
                VerticalAlignment="Stretch"
                HorizontalAlignment="Stretch">
                                <StackPanel VerticalAlignment="Top" HorizontalAlignment="Stretch">
                                    <TextBlock Text="Section" Margin="0,15,0,10" FontSize="15" FontWeight="SemiBold"/>
                                    <RadioButton x:Name="ServerSectionBtn"
                             Content="Server"
                             FontSize="15"
                             Height="42"
                                                 Margin="10,0,10,0"
                             IsChecked="True"
                             Checked="SectionChanged"/>
                                    <RadioButton x:Name="ThemeSectionBtn"
                             Content="Theme"
                             FontSize="15"
                             Height="42"
                             Margin="10,0,10,0"
                             Checked="SectionChanged"/>
                                </StackPanel>
                            </Border>

                            <!-- SERVER + ACCOUNT GRID -->
                            <Grid Grid.Column="1"
              x:Name="ServerAccountGrid"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              Visibility="{Binding IsChecked, ElementName=ServerSectionBtn, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <!-- ServerPanel wider -->
                                    <ColumnDefinition Width="*"/>
                                    <!-- AccountPanel narrower -->
                                </Grid.ColumnDefinitions>

                                <!-- SERVER CONFIG -->

                                <StackPanel Grid.Column="0" Margin="0,0,20,0" Name="ServerConfigPanel">

                                    <!-- SERVER DROPDOWN (NEW POSITION) -->
                                    <Border Background="{DynamicResource CardColor}" x:Name="ServerDropdownBorder"
            CornerRadius="12"
            Padding="14"
            BorderBrush="{DynamicResource BorderColor}"
            BorderThickness="1"
            Margin="0,0,0,10">

                                        <StackPanel HorizontalAlignment="Left">
                                            <TextBlock Text="Select Server"
                       Margin="10,0,0,10"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource FgColor}"/>

                                            <ComboBox x:Name="ServerDropdown"
                      SelectionChanged="ServerDropdown_SelectionChanged"
                      Height="42" MaxWidth="300" Margin="10,0,0,10">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Name}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>
                                    </Border>

                                    <!-- SERVER PANEL -->
                                    <Border MaxHeight="370"
            Background="{DynamicResource CardColor}"
            x:Name="ServerPanel"
            CornerRadius="12"
            Padding="14"
            BorderBrush="{DynamicResource BorderColor}"
            BorderThickness="1"
            VerticalAlignment="Stretch"
            HorizontalAlignment="Stretch">

                                        <ScrollViewer 
VerticalScrollBarVisibility="Hidden"
HorizontalScrollBarVisibility="Disabled"
CanContentScroll="True"
>
                                            <StackPanel Margin="0,10,10,10" HorizontalAlignment="Left">
                                                <TextBlock Foreground="{DynamicResource FgColor}" Text="Section Name"/>
                                                <TextBox x:Name="NameTextBox" Margin="10,0,0,10"/>
                                                <StackPanel Orientation="Horizontal" Margin="10,0,0,10" HorizontalAlignment="Left">
                                                    <TextBlock Foreground="{DynamicResource FgColor}" Text="Mode: "/>
                                                    <RadioButton x:Name="ModeOnlineRadio"
                                         Content="Online"
                                         Margin="0,0,10,0"
                                         GroupName="ModeGroup"/>
                                                    <RadioButton x:Name="ModeOfflineRadio"
                                         Content="Offline"
                                         GroupName="ModeGroup"/>
                                                </StackPanel>

                                                <TextBlock Foreground="{DynamicResource FgColor}" Text="Server Path"/>
                                                <TextBox x:Name="ServerPathTextBox"
                                 Margin="10,0,0,10"
                                 HorizontalAlignment="Stretch"
                                 IsReadOnly="True"
                                 Cursor="Hand"
                                 ToolTip="Click to select the server executable"
                                 PreviewMouseLeftButtonDown="ServerPathTextBox_Click"
                                 MouseLeftButtonUp="ServerPathTextBox_Click"/>

                                                <TextBlock Foreground="{DynamicResource FgColor}" Text="Client Path"/>
                                                <TextBox x:Name="ClientPathTextBox"
                                 Margin="10,0,0,10"
                                 HorizontalAlignment="Stretch"
                                 IsReadOnly="True"
                                 Cursor="Hand"
                                 ToolTip="Click to select the client executable"
                                 PreviewMouseLeftButtonDown="ClientPathTextBox_Click"
                                 MouseLeftButtonUp="ClientPathTextBox_Click"/>

                                                <TextBlock Foreground="{DynamicResource FgColor}" Text="Cache Dir"/>
                                                <TextBox x:Name="CacheDirTextBox"
                                 Margin="10,0,0,10"
                                 HorizontalAlignment="Stretch"
                                 Cursor="IBeam"
                                 ToolTip="Enter or click to select cache directory"
                                 MouseDoubleClick="CacheDirTextBox_DoubleClick"/>

                                                <TextBlock Foreground="{DynamicResource FgColor}" Text="Address"/>
                                                <ComboBox x:Name="AddressComboBox"
                                  Margin="10,0,0,10"
                                  IsEditable="True"
                                  IsReadOnly="False"
                                  StaysOpenOnEdit="True"
                                  HorizontalAlignment="Left"
                                  VerticalContentAlignment="Center"
                                  VerticalAlignment="Center"
                                  SelectionChanged="AddressComboBox_SelectionChanged"/>

                                                <TextBlock Foreground="{DynamicResource FgColor}" Text="Username"/>
                                                <TextBox x:Name="UsernameTextBox" Margin="10,0,0,10"/>

                                                <TextBlock Foreground="{DynamicResource FgColor}" Text="Token"/>
                                                <PasswordBox x:Name="TokenPasswordBox" Margin="10,0,0,10"/>

                                                <TextBlock Foreground="{DynamicResource FgColor}" Text="Log File"/>
                                                <TextBox x:Name="LogFileTextBox" Margin="10,0,0,10"/>

                                                <TextBlock Foreground="{DynamicResource FgColor}" Text="FPS Limit"/>
                                                <TextBox x:Name="FpsLimitTextBox" Margin="10,0,0,10"/>

                                                <TextBlock Foreground="{DynamicResource FgColor}" Text="Graphics API"/>
                                                <TextBox x:Name="GraphicsApiTextBox" Margin="10,0,0,10"/>

                                                <StackPanel Orientation="Horizontal" Margin="10,0,0,10">
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                                                        <CheckBox x:Name="VerboseCheckBox" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Verbose"
                                           Foreground="{DynamicResource FgColor}"
                                           VerticalAlignment="Center"
                                           Margin="6,0,0,0"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                                                        <CheckBox x:Name="DxvkHudCheckBox" VerticalAlignment="Center"/>
                                                        <TextBlock Text="DXVK HUD"
                                           Foreground="{DynamicResource FgColor}"
                                           VerticalAlignment="Center"
                                           Margin="6,0,0,0"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <CheckBox x:Name="FullscreenCheckBox" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Fullscreen"
                                           Foreground="{DynamicResource FgColor}"
                                           VerticalAlignment="Center"
                                           Margin="6,0,0,0"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <TextBlock Foreground="{DynamicResource FgColor}" Text="Image Path"/>
                                                <TextBox x:Name="ImagePathTextBox"
                                 Margin="10,0,0,10"
                                 Height="42"
                                 HorizontalAlignment="Stretch"
                                 IsReadOnly="True"
                                 Cursor="Hand"
                                 ToolTip="Click to choose background image"
                                 PreviewMouseLeftButtonDown="ImagePathTextBox_Click"
                                 MouseLeftButtonUp="ImagePathTextBox_Click"/>
                                            </StackPanel>

                                        </ScrollViewer>
                                    </Border>
                                </StackPanel>
                                <!-- ACCOUNT CONFIG -->
                                <ScrollViewer Grid.Column="1" x:Name="AccountPanel"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                                    <Border Background="{DynamicResource CardColor}"
                        CornerRadius="12"
                        Padding="14"
                        BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="1"
                        VerticalAlignment="Stretch"
                        HorizontalAlignment="Stretch">
                                        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Stretch">
                                            <TextBlock Text="Account" FontSize="16" FontWeight="Bold" Margin="0,0,0,12" Foreground="{DynamicResource FgColor}"/>
                                            <TextBlock Foreground="{DynamicResource FgColor}" Text="Email"/>
                                            <TextBox x:Name="EmailTextBox" HorizontalAlignment="Stretch" Margin="0,0,0,20"/>
                                            <TextBlock Foreground="{DynamicResource FgColor}" Text="Password"/>
                                            <PasswordBox x:Name="PasswordBox" HorizontalAlignment="Stretch" Margin="0"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                                <Button x:Name="FetchTokenButton"
                                    Content="Fetch Token"
                                    MinWidth="120"
                                    MinHeight="42"
                                    Click="FetchToken_Click"/>
                                                <Button x:Name="RegisterButton"
                                    Content="Register"
                                    MinWidth="120"
                                    Height="42"
                                    Click="Register_Click"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </ScrollViewer>
                            </Grid>

                            <!-- THEME COLUMN -->
                                <!-- THEME PANEL -->
                            <Border Background="{DynamicResource CardColor}" Grid.Column="1" Height="{Binding ActualHeight, ElementName=ServerAccountGrid}" Width="{Binding ActualWidth, ElementName=ServerAccountGrid}"
            CornerRadius="12"
            Padding="14"
            BorderBrush="{DynamicResource BorderColor}"
            BorderThickness="1"
                                    HorizontalAlignment="Stretch"
VerticalAlignment="Stretch"
            Visibility="{Binding IsChecked, ElementName=ThemeSectionBtn, Converter={StaticResource BoolToVisibilityConverter}}">

                                <StackPanel x:Name="ThemePanel"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Stretch">

                                    <TextBlock Text="Application Theme"
                       Margin="10,0,0,10"
                       FontSize="15"
                       FontWeight="Bold"
                       Foreground="{DynamicResource FgColor}"/>

                                    <ComboBox Margin="10,0,0,10"
                      x:Name="ThemeDropdown"
                      Height="42"/>

                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

                </Grid>

                <!-- FOOTER BUTTONS -->
                <Grid Grid.Row="3" HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Margin="20,10,20,20" x:Name="LaunchButton"
                            Content="Launch Game"
                            HorizontalAlignment="Stretch"
                            Click="LaunchButton_Click"/>

                    <Button Margin="20,0,20,20" x:Name="SaveButton"
                            Grid.Column="1"
                            Content="Save"
                            Visibility="Collapsed"
                            Click="Save_Click"/>
                </Grid>
            </Grid>
        </Border>
    </Viewbox>
</Window>
