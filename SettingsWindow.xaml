<Window x:Class="fflauncher.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Height="500" Width="700"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True">

    <!-- OUTER ROUNDED WINDOW CONTAINER -->
    <Border CornerRadius="16"
            Background="{DynamicResource BgColor}"
            BorderBrush="{DynamicResource BorderColor}"
            BorderThickness="1"
            SnapsToDevicePixels="True"
            ClipToBounds="True">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0"
        Height="32"
        Background="{DynamicResource BgColor}"
        CornerRadius="16,16,0,0"
        MouseDown="Window_MouseDown">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Title -->
                    <TextBlock Text="Settings"
                   VerticalAlignment="Center"
                   Margin="10,0,0,0"
                   Foreground="{DynamicResource FgColor}"
                   FontWeight="Bold"/>

                    <Button Grid.Column="1"
        Content="—"
        Width="40"
        Height="32"
        Margin="0"
        FontFamily="Segoe UI Symbol"
        FontSize="16"
        Foreground="{DynamicResource FgColor}"
        Click="Minimize_Click"
        Style="{StaticResource TitleBarButtonStyle}"/>

                    <Button Grid.Column="2"
        Content="□"
        Width="40"
        Height="32"
        Margin="0"
        FontFamily="Segoe UI Symbol"
        FontSize="16"
        Foreground="{DynamicResource FgColor}"
        Click="Maximize_Click"
        Style="{StaticResource TitleBarButtonStyle}"/>

                    <Button Grid.Column="3"
        Content="X"
        Width="40"
        Height="32"
        Margin="0"
        FontFamily="Segoe UI Symbol"
        FontSize="16"
        Foreground="{DynamicResource FgColor}"
        Click="Close_Click"
        Style="{StaticResource TitleBarCloseButtonStyle}"/>
                </Grid>
            </Border>
            
            <!-- Main Content -->
            <Grid Grid.Row="1" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT PANEL -->
                <Border Grid.Column="0"
                        Background="{DynamicResource CardColor}"
                        CornerRadius="12"
                        Padding="14"
                        Margin="0,0,10,0"
                        BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Servers" Margin="0,0,0,12" FontSize="16" FontWeight="Bold"/>

                        <TextBlock Text="Select Server" Margin="0,0,0,5" FontSize="15" FontWeight="SemiBold"/>
                        <ComboBox x:Name="ServerDropdown"
                                  SelectionChanged="ServerDropdown_SelectionChanged"
                                  Height="42"
                                  Margin="0,0,0,12">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" Foreground="{DynamicResource FgColor}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Text="Endpoint Preset" Margin="0,0,0,5" FontSize="15" FontWeight="SemiBold"/>
                        <ComboBox x:Name="EndpointPresetDropdown"
                                  SelectionChanged="EndpointPresetDropdown_SelectionChanged"
                                  Height="42"
                                  Margin="0,0,0,14">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" Foreground="{DynamicResource FgColor}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Text="Section" Margin="0,15,0,5" FontSize="15" FontWeight="SemiBold"/>

                        <RadioButton x:Name="ServerSectionBtn"
                                     Content="Server"
                                     FontSize="15"
                                     Height="42"
                                     IsChecked="True"
                                     Checked="SectionChanged"/>

                        <RadioButton x:Name="ThemeSectionBtn"
                                     Content="Theme"
                                     FontSize="15"
                                     Height="42"
                                     Margin="0,10,0,0"
                                     Checked="SectionChanged"/>

                    </StackPanel>
                </Border>

                <!-- RIGHT PANEL -->
                <Border Grid.Column="1"
        Background="{DynamicResource CardColor}"
        CornerRadius="12"
        Padding="10"
        BorderBrush="{DynamicResource BorderColor}"
        BorderThickness="1">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <!-- Content -->
                            <RowDefinition Height="Auto"/>
                            <!-- Buttons -->
                        </Grid.RowDefinitions>

                        <!-- CONTENT -->
                        <Grid Grid.Row="0">

                            <!-- SERVER SETTINGS PANEL -->
                            <ScrollViewer x:Name="ServerPanel"
                          VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="False"
                          PanningMode="VerticalOnly"
                          Margin="0,0,5,0"
                          PreviewMouseLeftButtonDown="SettingsScroll_MouseDown"
                          PreviewMouseMove="SettingsScroll_MouseMove"
                          PreviewMouseLeftButtonUp="SettingsScroll_MouseUp">
                                <StackPanel Margin="0,10,10,10">

                                    <TextBlock Foreground="{DynamicResource FgColor}" Text="Section Name"/>
                                    <TextBox x:Name="NameTextBox" Margin="0,0,0,10"/>

                                    <!-- MODE -->
                                    <TextBlock Foreground="{DynamicResource FgColor}" Text="Mode"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <RadioButton x:Name="ModeOnlineRadio"
                                         Content="Online"
                                         Margin="0,0,10,0"
                                         GroupName="ModeGroup"/>
                                                                <RadioButton x:Name="ModeOfflineRadio"
                                         Content="Offline"
                                         GroupName="ModeGroup"/>
                                    </StackPanel>

                                    <TextBlock Foreground="{DynamicResource FgColor}" Text="Server Path"/>
                                    <TextBox x:Name="ServerPathTextBox" Margin="0,0,0,10"/>

                                    <TextBlock Foreground="{DynamicResource FgColor}" Text="Client Path"/>
                                    <TextBox x:Name="ClientPathTextBox" Margin="0,0,0,10"/>

                                    <TextBlock Foreground="{DynamicResource FgColor}" Text="Cache Dir"/>
                                    <TextBox x:Name="CacheDirTextBox" Margin="0,0,0,10"/>

                                    <TextBlock Foreground="{DynamicResource FgColor}" Text="Address"/>
                                    <TextBox x:Name="AddressTextBox" Margin="0,0,0,10"/>

                                    <TextBlock Foreground="{DynamicResource FgColor}" Text="Username"/>
                                    <TextBox x:Name="UsernameTextBox" Margin="0,0,0,10"/>

                                    <TextBlock Foreground="{DynamicResource FgColor}" Text="Token"/>
                                    <TextBox x:Name="TokenTextBox" Margin="0,0,0,10"/>

                                    <TextBlock Foreground="{DynamicResource FgColor}" Text="Password"/>
                                    <PasswordBox x:Name="PasswordBox" Margin="0,0,0,10"/>

                                    <TextBlock Foreground="{DynamicResource FgColor}" Text="Email"/>
                                    <TextBox x:Name="EmailTextBox" Margin="0,0,0,10"/>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,10">
                                        <Button x:Name="FetchTokenButton" Content="Fetch Token" Width="120" Height="42" Margin="0,0,10,0" Click="FetchToken_Click"/>
                                        <Button x:Name="RegisterButton" Content="Register" Width="120" Height="42" Margin="0,0,10,0" Click="Register_Click"/>
                                    </StackPanel>

                                    <TextBlock Foreground="{DynamicResource FgColor}" Text="Log File:"/>
                                    <TextBox x:Name="LogFileTextBox" Margin="0,0,0,10"/>

                                    <TextBlock Foreground="{DynamicResource FgColor}" Text="FPS Limit:"/>
                                    <TextBox x:Name="FpsLimitTextBox" Margin="0,0,0,10"/>

                                    <TextBlock Foreground="{DynamicResource FgColor}" Text="Graphics API:"/>
                                    <TextBox x:Name="GraphicsApiTextBox" Margin="0,0,0,10"/>

                                    <!-- FLAGS ROW -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">

                                        <!-- VERBOSE -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                                            <CheckBox x:Name="VerboseCheckBox" VerticalAlignment="Center"/>
                                            <TextBlock Text="Verbose"
Foreground="{DynamicResource FgColor}"
VerticalAlignment="Center"
Margin="6,0,0,0"/>
                                        </StackPanel>

                                        <!-- DXVK HUD -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                                            <CheckBox x:Name="DxvkHudCheckBox" VerticalAlignment="Center"/>
                                            <TextBlock Text="DXVK HUD"
Foreground="{DynamicResource FgColor}"
VerticalAlignment="Center"
Margin="6,0,0,0"/>
                                        </StackPanel>

                                        <!-- FULLSCREEN -->
                                        <StackPanel Orientation="Horizontal">
                                            <CheckBox x:Name="FullscreenCheckBox" VerticalAlignment="Center"/>
                                            <TextBlock Text="Fullscreen"
Foreground="{DynamicResource FgColor}"
VerticalAlignment="Center"
Margin="6,0,0,0"/>
                                        </StackPanel>

                                    </StackPanel>

                                    
                                    <TextBlock Foreground="{DynamicResource FgColor}" Text="Image Path:"/>
                                    <TextBox x:Name="ImagePathTextBox"
                                             Margin="0,0,0,10"
                                             Height="42"
                                             HorizontalAlignment="Stretch"
                                             IsReadOnly="True"
                                             Cursor="Hand"
                                             ToolTip="Click to choose background image"
                                             MouseLeftButtonUp="ImagePathTextBox_Click"/>

                                </StackPanel>
                            </ScrollViewer>

                            <!-- THEME PANEL -->
                            <StackPanel x:Name="ThemePanel"
                        Visibility="Collapsed"
                        Margin="10">
                                <TextBlock Text="Application Theme" Margin="0,0,0,10" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource FgColor}"/>
                                <ComboBox x:Name="ThemeDropdown" Height="42"/>
                            </StackPanel>

                        </Grid>

                        <!-- BUTTONS -->
                        <Grid Grid.Row="1" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Content="Save"
                    Grid.Column="1"
                    Padding="15,5"
                    MinWidth="120"
                    Height="44"
                    Click="Save_Click"/>
                        </Grid>

                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>